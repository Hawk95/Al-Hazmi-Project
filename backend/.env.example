# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-secure-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────────────────────────────
# Render provides this automatically — copy it from your Render PostgreSQL dashboard
# Format: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DB_URL=postgresql+psycopg://user:password@host:5432/dbname

# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8003

# ── CORS ──────────────────────────────────────────────────────────────────────
# Add your Vercel frontend URL here after deployment
# Example: https://al-hazmi-erp.vercel.app,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
